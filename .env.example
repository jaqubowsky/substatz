# Database
# Use a strong, connection-string formatted URL to your production database
DATABASE_URL="mysql://username:password@localhost:3306/database"

AUTH_URL=http://localhost:3000
# Authentication
# Generate a long, random string (at least 32 characters) for AUTH_SECRET in production
# You can use: openssl rand -base64 32
AUTH_SECRET=your-production-auth-secret-at-least-32-chars
# Use your production domain (with https://)
AUTH_TRUST_HOST=true


# OAuth providers
# From your Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe (Live keys for production)
STRIPE_SECRET_KEY=sk_live_your-live-stripe-secret-key
STRIPE_PRICE_ID=price_your-live-stripe-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-live-webhook-signing-secret
STRIPE_API_VER=2025-02-24.acacia

ADMIN_EMAIL='test@email.com'

# Email (Resend)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=SubStatz <substatz@your-domain.com>

# CRON Secret (for protected API routes)
# Generate a long, random string (at least 32 characters)
# You can use: openssl rand -base64 32
CRON_SECRET=your-production-cron-secret-at-least-32-chars

# Exchange Rates API
EXCHANGE_RATES_API_KEY=your-exchange-rates-api-key
EXCHANGE_RATES_API_URL=https://v6.exchangerate-api.com/v6

# Client side
NEXT_PUBLIC_BASE_URL=https://your-production-domain.com
NEXT_PUBLIC_NODE_ENV=production
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
